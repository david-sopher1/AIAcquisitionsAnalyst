# ============================================================
# DealEngine environment configuration
# Copy to .env and fill in. Never commit .env.
# ============================================================

# --- Core ---
NODE_ENV=production
APP_BASE_URL=https://app.yourdomain.com
API_PORT=4000
DATABASE_URL=postgresql://dealengine:dealengine@localhost:5432/dealengine
REDIS_URL=redis://localhost:6379
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
WEBHOOK_SECRET=change-me-long-random-string
DASHBOARD_API_KEY=change-me-dashboard-key

# --- AI (Anthropic) ---
ANTHROPIC_API_KEY=sk-ant-...
# Default model for all agents. Override per-agent below if you want to trade
# quality for cost on high-volume paths (e.g. claude-sonnet-5, claude-haiku-4-5).
AI_MODEL_DEFAULT=claude-opus-4-8
AI_MODEL_CONVERSATION=claude-opus-4-8
AI_MODEL_EXTRACTION=claude-opus-4-8
AI_MODEL_SCORING=claude-opus-4-8

# --- Twilio (SMS/MMS + cold call infra, 10DLC registered) ---
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_MESSAGING_SERVICE_SID=MG...
TWILIO_FROM_NUMBER=+1...

# --- SendGrid (email) ---
SENDGRID_API_KEY=SG...
SENDGRID_FROM_EMAIL=offers@yourdomain.com
SENDGRID_FROM_NAME=Your Name

# --- Retell AI (AI voice calls) ---
RETELL_API_KEY=...
RETELL_AGENT_ID=...
RETELL_FROM_NUMBER=+1...

# --- Drop Cowboy (ringless voicemail) ---
DROPCOWBOY_TEAM_ID=...
DROPCOWBOY_SECRET=...
DROPCOWBOY_BRAND_ID=...

# --- Lob (direct mail) / Handwrytten (handwritten mail) ---
LOB_API_KEY=live_...
HANDWRYTTEN_API_KEY=...

# --- Data providers ---
BATCHDATA_API_KEY=...
ATTOM_API_KEY=...
PROPERTYRADAR_API_KEY=...

# --- Skip tracing ---
SKIPTRACE_PRIMARY=batchdata
# Premium waterfall vendor (optional): idi | enformion
SKIPTRACE_PREMIUM=
IDI_CLIENT_ID=
IDI_CLIENT_SECRET=

# --- CRM sync (optional; Postgres is the system of record) ---
GHL_API_KEY=
GHL_LOCATION_ID=

# --- Notifications (you, the closer) ---
OWNER_NAME=David
OWNER_PHONE=+1...
OWNER_EMAIL=davidsopher1@gmail.com
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# --- Compliance ---
# Global kill switch for all outbound. Set false to pause everything instantly.
OUTBOUND_ENABLED=true
# Max outbound SMS per lead per rolling 7 days (some states are stricter; the
# engine also applies per-state caps automatically).
SMS_WEEKLY_CAP=3
# National DNC scrub provider key (optional but recommended for cold calling)
DNC_SCRUB_API_KEY=

# --- Observability ---
LOG_LEVEL=info
SENTRY_DSN=
